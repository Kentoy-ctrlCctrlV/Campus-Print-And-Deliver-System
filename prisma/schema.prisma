// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                    String   @id @default(cuid())
  studentName           String
  studentEmailOrPhone   String
  status                String   @default("pending") // pending, printing, delivering, completed, cancelled
  totalPrice            Float
  paymentStatus         String   @default("pending") // pending, confirmed
  paymentMethod         String? // gcash, cash, etc.
  receiptUrl            String?
  deliveryAddress       String?
  notes                 String?
  
  fileItems             FileItem[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([studentEmailOrPhone])
  @@index([status])
  @@index([createdAt])
}

model FileItem {
  id                String   @id @default(cuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  fileName          String
  fileUrl           String
  fileSize          Float
  copies            Int      @default(1)
  colorMode         String?  // bw, color
  paperSize         String?  // A4, A3, Letter
  pageCount         Int?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([orderId])
}
