// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admin User model
model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // In production, this should be hashed
  email     String   @unique
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]

  @@map("admin_users")
}

// Student Order model
model Order {
  id                    String   @id @default(cuid())
  studentName           String
  studentEmailOrPhone   String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  status                String   @default("pending") // pending, printing, delivering, completed, cancelled
  estimatedCompletion   DateTime?
  deliveryBuilding      String
  printMode             String   // bw or color
  paperSize             String   // A4, short, long
  copies                Int
  pagesPerCopy          Int
  totalPages            Int
  totalPrice            Float
  paymentMethod         String   // gcash or cod
  paymentConfirmed      Boolean  @default(false)
  paymentConfirmedAt    DateTime?
  notes                 String?
  files                 FileItem[]
  statusHistory         OrderStatusHistory[]

  @@index([studentEmailOrPhone])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// File Item model
model FileItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name          String
  sizeInBytes   Int
  type          String   // pdf, doc, docx, other
  uploadedAt    DateTime @default(now())
  fileUrl       String?  // URL to stored file
  storagePath   String?  // Local or cloud storage path

  @@index([orderId])
  @@map("file_items")
}

// Order Status History for tracking changes
model OrderStatusHistory {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  previousStatus String
  newStatus     String
  changedAt     DateTime @default(now())
  changedBy     String   @default("system") // admin username or system
  notes         String?

  @@index([orderId])
  @@index([changedAt])
  @@map("order_status_history")
}

// Activity Log for admin actions
model ActivityLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String   // login, logout, order_update, order_delete, etc.
  orderId   String?  // if related to a specific order
  details   String?  // JSON string with additional details
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("activity_logs")
}

// Payment History model
model Payment {
  id                String   @id @default(cuid())
  orderId           String   @unique
  amount            Float
  paymentMethod     String   // gcash or cod
  status            String   @default("pending") // pending, confirmed, failed
  transactionId     String?  // Reference ID from payment gateway
  confirmedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orderId])
  @@index([createdAt])
  @@map("payments")
}
